#pragma once

// Twitch's PUBLIC client_id stays baked: Twitch Helix requires a Client-Id header on
// every API call, which the broker does not proxy. The secret is broker-held. Kick and
// YouTube ship nothing (their API calls use Bearer only); their OAuth goes through the broker.
#define TWITCH_CLIENTID "@TWITCH_CLIENTID@"
#define TWITCH_HASH     0x@TWITCH_HASH@

// The OAuth broker base URL (no trailing slash). Not a secret; overridable for self-host
// / third-party builds via the BRAIDCAST_BROKER_URL env var at configure time.
#define BRAIDCAST_BROKER_URL "@BRAIDCAST_BROKER_URL@"
