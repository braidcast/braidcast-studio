#pragma once

#define TWITCH_CLIENTID "@TWITCH_CLIENTID@"
#define TWITCH_HASH     0x@TWITCH_HASH@

#define KICK_CLIENTID    "@KICK_CLIENTID@"
#define KICK_HASH        0x@KICK_HASH@
#define KICK_SECRET      "@KICK_SECRET@"
#define KICK_SECRET_HASH 0x@KICK_SECRET_HASH@

#define YOUTUBE_CLIENTID    "@YOUTUBE_CLIENTID@"
#define YOUTUBE_HASH        0x@YOUTUBE_HASH@
#define YOUTUBE_SECRET      "@YOUTUBE_SECRET@"
#define YOUTUBE_SECRET_HASH 0x@YOUTUBE_SECRET_HASH@

// The OAuth broker base URL (no trailing slash). Not a secret; overridable for self-host
// / third-party builds via the BRAIDCAST_BROKER_URL env var at configure time.
#define BRAIDCAST_BROKER_URL "@BRAIDCAST_BROKER_URL@"
