---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
---

<Layout>
  <section class="hero">
    <h1>{SITE.name}</h1>
    <p class="lede">{SITE.tagline}</p>
    <p class="hero-desc">
      One encode, every destination. {SITE.name} lets you go live to multiple
      streaming platforms simultaneously from a single scene, without running
      several encoders on the same machine.
    </p>
    <p>
      <a class="btn" href="/privacy">Privacy Policy</a>
    </p>
  </section>

  <section>
    <h2>What it does</h2>
    <p class="muted">
      Composite once, fan out everywhere. {SITE.name} encodes your canvas a
      single time per resolution and multiplexes the result to each connected
      destination.
    </p>
    <div class="grid">
      <div class="card">
        <h3>Multistreaming</h3>
        <p class="muted">
          Broadcast to Twitch, YouTube, and Kick at the same time from one
          scene collection.
        </p>
      </div>
      <div class="card">
        <h3>Encode once</h3>
        <p class="muted">
          A single encode per canvas is reused across every destination, saving
          CPU and GPU headroom.
        </p>
      </div>
      <div class="card">
        <h3>Per-platform control</h3>
        <p class="muted">
          Connect each account with its own credentials and toggle destinations
          independently.
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2>Open source foundation</h2>
    <p class="muted">
      {SITE.name} is built on {SITE.builtOn} and distributed under the GNU
      General Public License v2 or later (GPLv2+).
    </p>
  </section>
</Layout>

<style>
  .hero {
    padding: 1rem 0 2rem;
  }

  .hero h1 {
    margin-bottom: 0.5rem;
  }

  .hero-desc {
    max-width: 42rem;
    margin-top: 1rem;
  }
</style>
